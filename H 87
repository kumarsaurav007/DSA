# Check if Array is Good :-

def isGood(self, nums: List[int]) -> bool:
        n = max(nums)

        if len(nums) != n + 1:
            return False
        
        freq = Counter(nums)

        for i in range(1, n):
            if freq[i] != 1:
                return False
        
        return freq[n] == 2

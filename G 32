# Minimum Initial Energy to Finish Tasks :-

def minimumEffort(self, tasks: List[List[int]]) -> int:
        tasks.sort(key=lambda x: x[1] - x[0], reverse=True)

        energy = 0
        ans = 0

        for actual, minimum in tasks:
            # Need enough energy to start task
            if energy < minimum:
                ans += minimum - energy
                energy = minimum

            # Finish task
            energy -= actual

        return ans

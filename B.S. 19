# Find Minimum in Rotated Sorted Array II :-

def findMin(self, nums: List[int]) -> int:
        n = len(nums)
        low = 0
        high = n-1
        if nums[low] < nums[high]:
            return nums[low]
        while low < high:
            mid = (low+high)//2
            if nums[mid] == nums[high]:
                high-=1
            elif nums[mid] > nums[high]:
                low = mid+1
            else:
                high = mid
        return nums[low]
            

# Sum of GCD of Formed Pairs :-

def gcdSum(self, nums: list[int]) -> int:
        arr = []
        mx = 0

        for x in nums:
            mx = max(mx, x)
            arr.append(gcd(x, mx))

        arr.sort()

        ans = 0
        n = len(arr)

        for i in range(n // 2):
            ans += gcd(arr[i], arr[n - 1 - i])

        return ans

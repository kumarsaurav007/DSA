# Maximum Distance Between a Pair of Values :-

def maxDistance(self, nums1: List[int], nums2: List[int]) -> int:
        max_dist = 0
        n = len(nums1)
        m = len(nums2)

        i, j = 0, 0
        while i < n and j < m:
            if nums1[i] <= nums2[j]:
                max_dist = max(max_dist, j - i)
                j += 1
            else:
                i += 1
        
        return max_dist

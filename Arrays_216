# Words Within Two Edits of Dictionary :-

def twoEditWords(self, queries: List[str], dictionary: List[str]) -> List[str]:
        res = []

        for query in queries:
            for word in dictionary:
                
                if len(query) == len(word):
                    change = 0
                    i, j = 0, 0
                    while i < len(query) and j < len(word):
                        if query[i] != word[j]:
                            change += 1
                            if change > 2:
                                break
                        i += 1
                        j += 1
                
                if change <= 2:
                    res.append(query)
                    break
        return res

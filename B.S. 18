# Find Minimum in Rotated Sorted Array :-

def findMin(self, nums: List[int]) -> int:
        n = len(nums)
        low = 0
        high = n-1
        if nums[low] <= nums[high]:
            return nums[0]
        while low <= high:
            mid = (low+high)//2
            if nums[mid] > nums[mid+1]:
                return nums[mid+1]
            elif nums[low] <= nums[mid]:
                low = mid+1
            else:
                high = mid-1
        return -1

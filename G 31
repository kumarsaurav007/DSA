# Minimum Swaps to Arrange a Binary Grid :-

def minSwaps(self, grid: List[List[int]]) -> int:
        n = len(grid)
    
        # Step 1: count trailing zeros
        trailing = []
        for row in grid:
            count = 0
            for num in reversed(row):
                if num == 0:
                    count += 1
                else:
                    break
            trailing.append(count)
        
        swaps = 0
        
        # Step 2: fix row by row
        for i in range(n):
            needed = n - 1 - i
            j = i
            
            # find a row with enough trailing zeros
            while j < n and trailing[j] < needed:
                j += 1
            
            if j == n:
                return -1
            
            # bubble it up
            while j > i:
                trailing[j], trailing[j - 1] = trailing[j - 1], trailing[j]
                swaps += 1
                j -= 1
        
        return swaps

# Earliest Finish Time for Land and Water Rides I :-

def earliestFinishTime(self, landStartTime: List[int], landDuration: List[int], waterStartTime: List[int], waterDuration: List[int]) -> int:
        ans = float('inf')

        for i in range(len(landStartTime)):
            for j in range(len(waterStartTime)):

                # Land -> Water
                finish_land = landStartTime[i] + landDuration[i]
                finish_water = max(waterStartTime[j], finish_land) + waterDuration[j]
                ans = min(ans, finish_water)

                # Water -> Land
                finish_water = waterStartTime[j] + waterDuration[j]
                finish_land = max(landStartTime[i], finish_water) + landDuration[i]
                ans = min(ans, finish_land)

        return ans

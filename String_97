# Lexicographically Smallest Generated String :-

def generateString(self, str1: str, str2: str) -> str:
        n, m = len(str1), len(str2)
        res = ['#'] * (n + m - 1)

        # Step 1: Apply 'T' constraints
        for i in range(n):
            if str1[i] == 'T':
                for j in range(m):
                    if res[i + j] != '#' and res[i + j] != str2[j]:
                        return ""
                    res[i + j] = str2[j]

        # Step 2: Fill remaining with 'a'
        for i in range(len(res)):
            if res[i] == '#':
                res[i] = 'a'

        # Step 3: Fix 'F' constraints
        for i in range(n):
            if str1[i] == 'F':
                # check if it matches str2
                match = True
                for j in range(m):
                    if res[i + j] != str2[j]:
                        match = False
                        break

                # if equal, break it
                if match:
                    changed = False

                    # try from rightmost position
                    for j in range(m - 1, -1, -1):
                        idx = i + j
                        original = res[idx]

                        # try changing this character
                        for ch in range(26):
                            new_char = chr(ord('a') + ch)
                            if new_char == original:
                                continue

                            res[idx] = new_char

                            # check all affected 'T' constraints
                            valid = True
                            for k in range(max(0, idx - m + 1), min(n, idx + 1)):
                                if str1[k] == 'T':
                                    for t in range(m):
                                        if res[k + t] != str2[t]:
                                            valid = False
                                            break
                                if not valid:
                                    break

                            if valid:
                                changed = True
                                break

                            res[idx] = original  # revert

                        if changed:
                            break

                    if not changed:
                        return ""

        return "".join(res)

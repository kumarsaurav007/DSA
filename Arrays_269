# Shift 2D Grid :-

def shiftGrid(self, grid: List[List[int]], k: int) -> List[List[int]]:
        m, n = len(grid), len(grid[0])

        arr = []
        for row in grid:
            arr.extend(row)

        total = m * n
        k %= total

        arr = arr[-k:] + arr[:-k]

        ans = [[0] * n for _ in range(m)]

        idx = 0
        for i in range(m):
            for j in range(n):
                ans[i][j] = arr[idx]
                idx += 1

        return ans

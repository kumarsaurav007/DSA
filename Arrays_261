# Count Subarrays With Majority Element II :-

from bisect import bisect_left

class BIT:
    def __init__(self, n):
        self.bit = [0] * (n + 1)

    def update(self, i, val):
        while i < len(self.bit):
            self.bit[i] += val
            i += i & -i

    def query(self, i):
        s = 0
        while i > 0:
            s += self.bit[i]
            i -= i & -i
        return s

class Solution:
    def countMajoritySubarrays(self, nums: List[int], target: int) -> int:
        pref = [0]

        cur = 0
        for x in nums:
            if x == target:
                cur += 1
            else:
                cur -= 1
            pref.append(cur)

        vals = sorted(set(pref))
        bit = BIT(len(vals))

        ans = 0

        for x in pref:
            idx = bisect_left(vals, x) + 1

            # count previous prefix sums < x
            ans += bit.query(idx - 1)

            bit.update(idx, 1)

        return ans

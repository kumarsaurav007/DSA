# Find the Maximum Number of Elements in Subset :-

def maximumLength(self, nums: List[int]) -> int:
        cnt = Counter(nums)
        ans = 1

        # special handling for 1
        if 1 in cnt:
            c = cnt[1]
            ans = max(ans, c if c % 2 else c - 1)

        for x in cnt:
            if x == 1:
                continue

            cur = x
            length = 0

            while cnt[cur] >= 2:
                length += 2
                if cur * cur > 10**9:
                    break
                cur *= cur

            if cnt[cur] == 1:
                length += 1
            else:
                length -= 1

            ans = max(ans, length)

        return ans

# Rotate Function :-

def maxRotateFunction(self, nums: List[int]) -> int:
        n = len(nums)
        
        total = sum(nums)
        F = sum(i * num for i, num in enumerate(nums))
        
        res = F
        
        for k in range(1, n):
            F = F + total - n * nums[n - k]
            res = max(res, F)
        
        return res

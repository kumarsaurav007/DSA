# Search in Rotated Sorted Array :-

def search(self, nums: List[int], target: int) -> int:
        n = len(nums)
        low = 0
        high = n -1

        while low <= high:
            mid = (low + high) // 2
            
            if nums[mid] == target:
                return mid

            # 1st part is sorted?
            if nums[low] <= nums[mid]:
                # target lies in sorted part
                if nums[low] <= target and target < nums[mid]:
                    high = mid - 1
                # target do not lie in sorted part
                else:
                    low = mid + 1
            
            # 2nd part is sorted?
            else:
                # target lie in sorted part
                if nums[mid] < target and target <= nums[high]:
                    low = mid + 1
                # target do not lie in this part
                else:
                    high = mid - 1
            
        return -1

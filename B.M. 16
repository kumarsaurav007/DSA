# XOR After Range Multiplication Queries I :-

def xorAfterQueries(self, nums: List[int], queries: List[List[int]]) -> int:
        MOD = 10**9 + 7
        
        for l, r, k, v in queries:
            idx = l
            while idx <= r:
                nums[idx] = (nums[idx] * v) % MOD
                idx += k
        
        # Compute XOR
        result = 0
        for num in nums:
            result ^= num
        
        return result

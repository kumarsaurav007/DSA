# Minimum Cost of Buying Candies With Discount :-

def minimumCost(self, cost: List[int]) -> int:
        cost.sort(reverse=True)
        n = len(cost)

        output = sum(cost)

        if n < 3:
            return output
        
        for i in range(n):
            if (i + 1) % 3 == 0:
                output -= cost[i]

        return output
